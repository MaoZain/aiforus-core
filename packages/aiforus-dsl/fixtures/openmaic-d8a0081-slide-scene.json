    { "id": "a-wb-latex", "type": "wb_draw_latex", "latex": "x^2", "x": 20, "y": 300 },
    {
      "id": "a-wb-table",
      "type": "wb_draw_table",
      "x": 250,
      "y": 300,
      "width": 300,
      "height": 160,
      "data": [
        ["Name", "Value"],
        ["A", "1"]
      ]
    },
    {
      "id": "a-wb-line",
      "type": "wb_draw_line",
      "startX": 20,
      "startY": 500,
      "endX": 300,
      "endY": 500
    },
    {
      "id": "a-wb-code",
      "type": "wb_draw_code",
      "language": "typescript",
      "code": "const compatible = true;",
      "x": 350,
      "y": 20
    },
    {
      "id": "a-wb-edit-code",
      "type": "wb_edit_code",
      "elementId": "code-1",
      "operation": "replace_lines",
      "lineIds": ["L1"],
      "content": "const compatible = true;"
    },
    { "id": "a-wb-clear", "type": "wb_clear" },
    { "id": "a-wb-delete", "type": "wb_delete", "elementId": "shape-1" },
    { "id": "a-wb-close", "type": "wb_close" },
    { "id": "a-discussion", "type": "discussion", "topic": "Why freeze the contract?" },
    { "id": "a-widget-highlight", "type": "widget_highlight", "target": "#result" },
    { "id": "a-widget-state", "type": "widget_setState", "state": { "value": 1 } },
    { "id": "a-widget-annotation", "type": "widget_annotation", "target": "#axis" },
    { "id": "a-widget-reveal", "type": "widget_reveal", "target": "#answer" }
  ]
