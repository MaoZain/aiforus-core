{
  "name": "@aiforus/dsl",
  "version": "0.1.0-alpha.0",
  "description": "OpenMAIC-compatible courseware contracts, schemas, validators, and migrations maintained by AIForUs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/*": "./dist/schema/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "pnpm clean && tsc -p tsconfig.json && node scripts/gen-schema.mjs",
    "build:schema": "node scripts/gen-schema.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaoZain/aiforus-core.git",
    "directory": "packages/aiforus-dsl"
  },
  "homepage": "https://github.com/MaoZain/aiforus-core#readme",
  "bugs": {
    "url": "https://github.com/MaoZain/aiforus-core/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "aiforus",
    "openmaic",
    "dsl",
    "slide",
    "schema",
    "contract"
  ],
  "devDependencies": {
    "ajv": "8.17.1",
    "ts-json-schema-generator": "2.4.0"
  }
}
