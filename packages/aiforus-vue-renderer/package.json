{
  "name": "@aiforus/vue-renderer",
  "version": "0.1.0-alpha.1",
  "description": "Vue 3 slide renderer and action player for the AIForUs OpenMAIC-compatible DSL.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "pnpm --filter @aiforus/dsl build && pnpm clean && vite build && vue-tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "gallery": "vite --config gallery/vite.config.ts",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @aiforus/dsl build && vue-tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaoZain/aiforus-core.git",
    "directory": "packages/aiforus-vue-renderer"
  },
  "homepage": "https://github.com/MaoZain/aiforus-core#readme",
  "bugs": {
    "url": "https://github.com/MaoZain/aiforus-core/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@aiforus/dsl": "workspace:^"
  },
  "peerDependencies": {
    "vue": ">=3.4.0 <4"
  },
  "devDependencies": {
    "@vue/compiler-sfc": "3.4.30",
    "@vue/server-renderer": "3.4.30",
    "@vue/test-utils": "2.4.11",
    "jsdom": "29.1.1",
    "vue": "3.4.30",
    "vue-tsc": "3.3.7"
  }
}
